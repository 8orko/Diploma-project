# This file stores environment-specific variables.
# For example, database credentials, API keys, and JWT secrets.
# IMPORTANT: This file should be added to .gitignore and should not be committed to version control.

# JWT secret key for signing and verifying tokens.
# Use a long, random, and complex string in production.
JWT_SECRET=your_super_secret_key_for_development

# The port the server will run on.
PORT=5000
